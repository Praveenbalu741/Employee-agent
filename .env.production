# Production Environment Template
# Copy this file and fill in actual values for production deployment

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas (REQUIRED - get from https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/employee-feedback?retryWrites=true&w=majority

# JWT Secrets (REQUIRED - generate secure random strings)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic Claude AI (REQUIRED)
ANTHROPIC_API_KEY=

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com

# Frontend Origin (Update with your frontend URL)
CLIENT_ORIGIN=https://your-frontend-domain.vercel.app
